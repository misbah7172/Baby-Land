# Backend Express.js Environment Variables - Template
# Copy this file to .env.backend and update values for your environment

NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================

# For docker-compose (MySQL runs inside container at hostname 'mysql')
DATABASE_URL_DOCKER=mysql://baby_land:baby_land_password@mysql:3306/baby_land

# For local development (connects to localhost MySQL)
DATABASE_URL=mysql://baby_land:baby_land_password@localhost:3306/baby_land

# For Railway production (auto-injected by Railway)
# DATABASE_URL=mysql://user:password@host:port/database

# ============================================
# REDIS CONFIGURATION
# ============================================

# For docker-compose
REDIS_URL=redis://redis:6379

# For Railway production
# REDIS_URL=redis://default:password@host:port

# ============================================
# JWT SECRETS - PRODUCTION REQUIREMENTS
# ============================================
# Must be at least 32 characters in production
# Must contain uppercase, lowercase, numbers, and special characters

# IMPORTANT: CHANGE THESE IN PRODUCTION!
JWT_ACCESS_SECRET=dev-secret-key-replace-in-production-12345678
JWT_REFRESH_SECRET=dev-refresh-key-replace-in-production-12345678

# ============================================
# SERVER CONFIGURATION
# ============================================

PORT=4000
HOST=0.0.0.0

# ============================================
# CORS AND ORIGIN CONFIGURATION
# ============================================

# Frontend URL (where users access the app from)
FRONTEND_URL=http://localhost:3000

# Backend URL (public-facing backend URL)
BACKEND_URL=http://localhost:4000

# CORS Origin (what requests to accept)
CORS_ORIGIN=http://localhost:3000

# Cookie Configuration
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ============================================
# ADMIN CONFIGURATION
# ============================================

ADMIN_EMAIL=admin@babyland.local
ADMIN_PASSWORD=Admin12345!

# ============================================
# LOGGING
# ============================================

# Log levels: debug, info, warn, error
LOG_LEVEL=debug

# ============================================
# RATE LIMITING (optional)
# ============================================

# Time window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window
RATE_LIMIT_MAX_REQUESTS=200

# ============================================
# MYSQL SERVICE CONFIGURATION
# ============================================
# Used for docker-compose health checks

MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=baby_land
MYSQL_USER=baby_land
MYSQL_PASSWORD=baby_land_password

# ============================================
# RAILWAY DEPLOYMENT - EXAMPLE
# ============================================
# When deploying to Railway, set these values in Railway Dashboard:
# 
# NODE_ENV=production
# FRONTEND_URL=https://your-frontend.railway.app
# BACKEND_URL=https://your-backend.railway.app
# CORS_ORIGIN=https://your-frontend.railway.app
# DATABASE_URL=<Railway MySQL connection string>
# REDIS_URL=<Railway Redis connection string>
# JWT_ACCESS_SECRET=<Generate strong 32+ char secret>
# JWT_REFRESH_SECRET=<Generate strong 32+ char secret>
# COOKIE_DOMAIN=your-frontend.railway.app
# COOKIE_SECURE=true
