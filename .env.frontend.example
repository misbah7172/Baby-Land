# Frontend Next.js Environment Variables - Template
# Copy this file to .env.frontend and update values for your environment

NODE_ENV=development

# ============================================
# NEXT.JS CONFIGURATION
# ============================================

PORT=3000
HOSTNAME=0.0.0.0

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# ============================================
# BACKEND API CONFIGURATION
# ============================================

# Public URL for browser requests (what frontend users see)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Internal URL for server-side requests (inside docker-compose network)
# For docker-compose: use 'http://backend:4000'
# For local dev: use 'http://localhost:4000'
BACKEND_API_URL=http://backend:4000

# ============================================
# COOKIE CONFIGURATION
# ============================================

COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ============================================
# FIREBASE CONFIGURATION (Client-side safe)
# ============================================
# These are public API keys - safe to expose to browser

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDUHnZy_K9_hwkgbOwEcntU1iYP0J8WBdw
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=baby-land-7172.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=baby-land-7172
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=baby-land-7172.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=321730061397
NEXT_PUBLIC_FIREBASE_APP_ID=1:321730061397:web:06c4ddf2dee9a09cbfa0dc

# ============================================
# ADMIN CONFIGURATION (Client-side accessible)
# ============================================

# Admin dashboard secret path (obfuscation, not security)
NEXT_PUBLIC_ADMIN_PATH=458901

# Admin email and password hash (for login)
NEXT_PUBLIC_ADMIN_EMAIL=misbah244176@gmail.com
NEXT_PUBLIC_ADMIN_PASSWORD_HASH=koko458901

# ============================================
# RAILWAY DEPLOYMENT - EXAMPLE
# ============================================
# When deploying to Railway, set these values in Railway Dashboard:
# 
# NODE_ENV=production
# NEXT_PUBLIC_BACKEND_URL=https://your-backend.railway.app
# BACKEND_API_URL=https://your-backend.railway.app
# COOKIE_DOMAIN=your-frontend.railway.app
# COOKIE_SECURE=true
#
# Firebase, admin, and other public keys remain the same
