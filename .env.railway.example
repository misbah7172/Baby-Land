# ============================================================================
# Railway Deployment Environment Variables
# ============================================================================
# This file contains all environment variables needed for Baby Land 
# deployment on Railway with MySQL and Redis services.
# 
# Usage:
# 1. Copy this file: cp .env.railway.example .env.railway
# 2. Fill in the values in Railway dashboard under Service > Variables
# 3. Ensure services are connected (Database link and Redis plugin)
# ============================================================================

# ============================================================================
# Core Environment
# ============================================================================
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# ============================================================================
# Frontend Configuration
# ============================================================================
# The public-facing URL where the frontend is deployed on Railway
# Example: https://baby-land-frontend-username.railway.app
FRONTEND_URL=https://your-frontend-railway-url.railway.app

# The backend URL accessible from frontend
# Usually the Railway backend service URL with /api prefix
# Example: https://baby-land-backend-username.railway.app
BACKEND_URL=https://your-backend-railway-url.railway.app

# CORS origin - must match FRONTEND_URL exactly
CORS_ORIGIN=https://your-frontend-railway-url.railway.app

# ============================================================================
# Database Configuration (MySQL)
# ============================================================================
# Railway auto-injects this when MySQL plugin is attached to the service
# Format: mysql://username:password@host:port/database
# Connection pooling is included in Railway's MySQL service
DATABASE_URL=mysql://railway:password@localhost:3306/railway

# ============================================================================
# Redis Configuration (Optional)
# ============================================================================
# Railway auto-injects this when Redis plugin is attached
# Leave empty to disable Redis (caching falls back to memory)
# Format: redis://default:password@host:port
REDIS_URL=redis://default:password@localhost:6379

# ============================================================================
# Security & JWT
# ============================================================================
# Generate strong secrets! Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 
# IMPORTANT: These MUST be at least 32 characters with uppercase, numbers, and special characters
# in production. Use a password manager to generate these.

# JWT Access Token Secret (used for short-lived auth tokens)
JWT_ACCESS_SECRET=your-secret-key-min-32-chars-with-UPPERCASE-123-!@#

# JWT Refresh Token Secret (used for refresh token rotation)
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-with-UPPERCASE-456-$%^

# ============================================================================
# Cookie Configuration
# ============================================================================
# For Railway custom domain: use the custom domain
# For Railway subdomain: leave empty
# Important: Secure cookies require HTTPS (which Railway provides)
COOKIE_DOMAIN=your-custom-domain.com
COOKIE_SECURE=true

# ============================================================================
# Admin Account
# ============================================================================
# Create a strong admin password!
# IMPORTANT: Change this immediately after first login and store securely.
# 
# Password Requirements in Production:
# - Minimum 12 characters
# - Must contain uppercase letters
# - Must contain numbers
# - Must contain special characters (!@#$%^&*)

ADMIN_EMAIL=admin@your-company.com
ADMIN_PASSWORD=ChangeMe@2024!StrongPass123

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
# Window duration for rate limiting (milliseconds)
# Default: 15 minutes = 900000 ms
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
# Default: 200 requests per 15 minutes
RATE_LIMIT_MAX_REQUESTS=200

# ============================================================================
# Advanced Settings (Optional)
# ============================================================================
# Only change these if you know what you're doing

# Enable request/response logging (development only, set to 'info' for production)
# LOG_LEVEL=info

# ============================================================================
# Verification Checklist Before Deployment
# ============================================================================
# ✓ All required fields are filled in
# ✓ DATABASE_URL points to your MySQL database
# ✓ FRONTEND_URL uses HTTPS
# ✓ BACKEND_URL uses HTTPS
# ✓ JWT secrets are at least 32 characters with complexity
# ✓ ADMIN_EMAIL is changed from default
# ✓ ADMIN_PASSWORD is strong and changed from default
# ✓ COOKIE_SECURE is set to true
# ✓ COOKIE_DOMAIN is set to your actual domain
# ✓ Redis is configured (or left empty for memory cache)
# ============================================================================
