# Render deployment environment variables
# Use this file as the source when filling Render dashboard env vars.
# Do not commit real secrets.

# -----------------------------
# Shared
# -----------------------------
NODE_ENV=production
COOKIE_SECURE=true

# Use long random values. Keep both services in sync.
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string

# -----------------------------
# Backend service: baby-land-backend
# -----------------------------
PORT=4000
PRISMA_PROVIDER=postgres

# Replace <project-ref> and <password> with your Supabase values.
DATABASE_URL=postgresql://postgres.tiqforrjgvfnlfvafssj:W2TpuCXhKxtwL3cc@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1

# Set these to your public frontend URL after frontend is deployed.
FRONTEND_URL=https://your-frontend.onrender.com
BACKEND_URL=https://your-backend.onrender.com
CORS_ORIGIN=https://your-frontend.onrender.com

# For Render subdomains, keep COOKIE_DOMAIN empty.
# If you use a custom root domain for both apps, set it like: yourdomain.com
COOKIE_DOMAIN=

ADMIN_EMAIL=admin@babyland.local
ADMIN_PASSWORD=ChangeThisAdminPassword123!

# REDIS_URL is auto-wired from render.yaml for backend.
# REDIS_URL=redis://...

# -----------------------------
# Frontend service: baby-land-frontend
# -----------------------------
PORT=3000
HOSTNAME=0.0.0.0

# Backend URL used by frontend server and browser.
BACKEND_API_URL=https://your-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL=https://your-backend.onrender.com

# Keep this empty for Render subdomains.
# For custom root domain shared by both apps, set: yourdomain.com
COOKIE_DOMAIN=

NEXT_PUBLIC_ADMIN_PATH=458901
NEXT_PUBLIC_ADMIN_EMAIL=misbah244176@gmail.com
NEXT_PUBLIC_ADMIN_PASSWORD_HASH=koko458901

# Firebase public config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDUHnZy_K9_hwkgbOwEcntU1iYP0J8WBdw
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=baby-land-7172.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=baby-land-7172
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=baby-land-7172.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=321730061397
NEXT_PUBLIC_FIREBASE_APP_ID=1:321730061397:web:06c4ddf2dee9a09cbfa0dc

