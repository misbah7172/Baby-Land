# Vercel deployment environment variables
# Set these in Vercel Project Settings > Environment Variables

NODE_ENV=production

# Frontend runtime variables for the hybrid architecture
REDIS_URL=redis://your-redis-host:6379
BACKEND_API_URL=https://your-backend.example.com
NEXT_PUBLIC_BACKEND_URL=https://your-backend.example.com

# App auth variables
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string

# Optional cookie domain override (leave empty unless needed).
# Use domain only, e.g. baby-land.vercel.app (no https:// and no path).
COOKIE_DOMAIN=

